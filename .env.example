# SynSight environment configuration
# Copy to .env.local (dev) or .env.production (server) and fill in real values.

# MariaDB / MySQL connection string (self-hosted Debian server)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Example (MariaDB on localhost):
#   DATABASE_URL=mysql://synsight_user:STRONG_PASSWORD@localhost:3306/synsight
# mysql2 speaks the MySQL protocol — works with MariaDB 10.11+ / 11.x.
# Leave unset for in-memory repository fallbacks during local UI work.
DATABASE_URL=mysql://synsight:change-me@localhost:3306/synsight

# Staging/production must set REQUIRE_DATABASE=true (production implies required).
REQUIRE_DATABASE=false

# Secret for signing session cookies (min. 32 characters; required in production)
SESSION_SECRET=change-me-to-a-long-random-secret-at-least-32

# Optional dedicated key for encrypting private image originals (falls back to SESSION_SECRET)
# IMAGE_ENCRYPTION_KEY=

# Optional absolute root for private media (default: ./storage/private)
# PRIVATE_STORAGE_ROOT=

# Public application URL (used for redirects, verification links, CSRF origin checks)
APP_URL=http://localhost:3000

# Development-only auth shortcuts. Must remain "false" in production.
ALLOW_DEV_AUTH=false

# Email verification delivery mode:
# - log-link: write verification URLs to server logs (local/dev)
# - disabled: skip outbound delivery (tokens still issued)
# - provider: reserved for a future mail provider integration (needs EMAIL_PROVIDER_API_KEY)
EMAIL_DELIVERY_MODE=log-link

# Public self-registration (set false to lock)
ALLOW_PUBLIC_REGISTRATION=true

# Activate new users immediately only for local tests.
# Keep false when testing the real email-verification flow.
AUTO_VERIFY_EMAIL=false

# SMTP settings required when EMAIL_DELIVERY_MODE=provider
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=SynSight <noreply@synsight.de>

# Reject POSTs without Origin/Referer (default: true in production, false in development)
# CSRF_STRICT=false
