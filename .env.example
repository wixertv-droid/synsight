# SynSight environment configuration
# Copy to .env.local and fill in real values before deployment.

# MySQL connection string (self-hosted server)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://synsight:change-me@localhost:3306/synsight

# Secret for signing session cookies (min. 32 random bytes)
SESSION_SECRET=change-me-to-a-long-random-secret

# Public application URL (used for redirects, emails, webhooks)
APP_URL=http://localhost:3000
