# SynSight production environment template
# Copy to the deployment host and inject secrets via your secret manager.

NODE_ENV=production

# Required: reachable MySQL 8 instance
DATABASE_URL=mysql://synsight:REPLACE_ME@db.internal:3306/synsight

# Required: >= 32 random characters
SESSION_SECRET=REPLACE_WITH_CRYPTOGRAPHICALLY_RANDOM_SECRET_32PLUS

# Recommended: dedicated AES key material for private image originals
IMAGE_ENCRYPTION_KEY=REPLACE_WITH_SEPARATE_32PLUS_RANDOM_SECRET

# Canonical public origin (https://synsight.de)
APP_URL=https://synsight.de

# Must remain false in production
ALLOW_DEV_AUTH=false

# Keep disabled until a real outbound provider adapter is wired
EMAIL_DELIVERY_MODE=disabled

# Absolute private storage root outside the web root
PRIVATE_STORAGE_ROOT=/var/lib/synsight/private
