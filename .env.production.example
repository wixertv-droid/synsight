# SynSight production / server testing environment
# Copy values into PM2 env, systemd, or .env on the host.

NODE_ENV=production
REQUIRE_DATABASE=true

DATABASE_URL=mysql://synsight:REPLACE_ME@localhost:3306/synsight
SESSION_SECRET=REPLACE_WITH_CRYPTOGRAPHICALLY_RANDOM_SECRET_32PLUS
IMAGE_ENCRYPTION_KEY=REPLACE_WITH_SEPARATE_32PLUS_RANDOM_SECRET

# Must match the HTTPS URL users open in the browser (CSRF + cookies + verify links)
APP_URL=https://synsight.de

# Nginx should forward: Host, X-Forwarded-Host, X-Forwarded-Proto, X-Forwarded-For
# Session cookies: HttpOnly + SameSite=Lax; Secure when APP_URL is https://

# --- Auth open for database testing ---
ALLOW_PUBLIC_REGISTRATION=true
AUTO_VERIFY_EMAIL=true
EMAIL_DELIVERY_MODE=log-link
# Missing Origin rejected in production; browser same-origin login still works
CSRF_STRICT=true
ALLOW_DEV_AUTH=false
COOKIE_SECURE=true

PRIVATE_STORAGE_ROOT=/var/lib/synsight/private
