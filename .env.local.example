# Copy to .env.local for local development against MariaDB.
# On the Debian production server, prefer systemd/PM2 env or .env.production.

DATABASE_URL=mysql://synsight_user:STRONG_PASSWORD@localhost:3306/synsight
REQUIRE_DATABASE=true
SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-chars
APP_URL=http://localhost:3000
ALLOW_DEV_AUTH=false
EMAIL_DELIVERY_MODE=log-link
ALLOW_PUBLIC_REGISTRATION=false
